#compdef claude

# Zsh completion script for Claude Code CLI
# https://github.com/anthropics/claude-code
# Auto-generated for Claude v2.1.119

_claude_session_ids() {
  # Claude stores each project under ~/.claude/projects/ with a mangled
  # folder name: both `/` and `.` are replaced with `-`. The prior version
  # only handled `/`, so any hidden-directory path (e.g. `/Users/x/.fabro/y`)
  # silently returned no completions.
  local mangled="${PWD//\//-}"
  mangled="${mangled//./-}"
  local project_dir="$HOME/.claude/projects/$mangled"

  # Fallback: if the mangled folder isn't found (e.g. unknown future naming
  # scheme, or the session was created from a different canonical path such
  # as a resolved symlink), locate the project by matching the authoritative
  # `originalPath` recorded in each sessions-index.json.
  if [[ ! -d "$project_dir" ]]; then
    project_dir=""
    local f
    for f in "$HOME/.claude/projects"/*/sessions-index.json(N); do
      if [[ "$(python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("originalPath",""))' < "$f" 2>/dev/null)" == "$PWD" ]]; then
        project_dir="${f:h}"
        break
      fi
    done
    [[ -z "$project_dir" ]] && return 1
  fi

  local index_file="$project_dir/sessions-index.json"
  local -a ids labels

  # Cap the number of sessions offered by completion. Projects with a long
  # history can accumulate hundreds of session files — enumerating them all
  # triggers zsh's "show all N possibilities?" pager prompt and (worse)
  # forces the expensive JSONL parse below to run once per file on every
  # TAB press. Default to the 20 most recent; override via
  # CLAUDE_COMPLETION_SESSION_LIMIT, where 0 (or any non-positive int)
  # disables the cap for users who want the old behavior.
  local max_sessions=${CLAUDE_COMPLETION_SESSION_LIMIT:-20}

  # Two-pass enumeration. Pass 1 collects cheap candidates keyed by an
  # ISO-ish timestamp; pass 2 resolves branch/message only for the top N.
  # Candidate line format:
  #   "<sortkey>\t<uuid>\tindex\t<branch>\t<summary>"  (already resolved)
  #   "<sortkey>\t<uuid>\tjsonl"                      (resolve in pass 2)
  local -a candidates
  local -A indexed

  # Indexed sessions — one jq call gives us everything cheaply, so keep
  # branch/summary inline and skip pass 2 for these.
  if [[ -f "$index_file" ]]; then
    while IFS=$'\t' read -r modified id branch summary; do
      [[ -z "$id" ]] && continue
      indexed[$id]=1
      candidates+=("${modified}"$'\t'"${id}"$'\tindex\t'"${branch}"$'\t'"${summary}")
    done < <(python3 -c '
import sys, json
try:
    data = [json.loads(l) for l in sys.stdin if l.strip()]
    entries = []
    for obj in data:
        e = obj.get("entries") or {}
        vals = e.values() if isinstance(e, dict) else e
        entries.extend(vals)
    for e in entries:
        modified = e.get("modified", "")
        sid = e.get("sessionId", "")
        branch = e.get("gitBranch") or "?"
        summary = e.get("summary") or (e.get("firstPrompt") or "")[:60]
        print(f"{modified}\t{sid}\t{branch}\t{summary}")
except Exception:
    pass
' < "$index_file" 2>/dev/null)
  fi

  # Unindexed JSONL files — just mtime+uuid here; the expensive head|jq
  # parse is deferred until we know the candidate survived the cap. Use
  # zsh parameter expansion (`${zf:t:r}`) and the zsh/stat + zsh/datetime
  # builtins (zstat, strftime) to avoid forking a subshell per file: these
  # are pure builtins and work on both BSD/macOS and GNU/Linux.
  #
  # Note: all locals used below are declared once here, up-front. zsh
  # prints the current value of a variable when `local`/`typeset` is
  # applied to it a second time in the same scope (treats it like
  # `typeset -p`), so pass 2 must *not* redeclare these.
  local -a jsonl_files _zst top
  local line iso_mtime uuid sortkey src branch msg datestr info zf
  local count=0 headroom

  zmodload -F zsh/stat b:zstat 2>/dev/null
  zmodload -F zsh/datetime b:strftime 2>/dev/null

  jsonl_files=( "$project_dir"/*.jsonl(N) )
  if (( ${#jsonl_files} > 0 )); then
    for zf in "${jsonl_files[@]}"; do
      _zst=()
      zstat -A _zst +mtime -- "$zf" 2>/dev/null || continue
      strftime -s iso_mtime '%Y-%m-%dT%H:%M:%S' ${_zst[1]}
      uuid="${zf:t:r}"
      [[ -n "${indexed[$uuid]}" ]] && continue
      candidates+=("${iso_mtime}"$'\t'"${uuid}"$'\tjsonl')
    done
  fi

  # Sort descending by sortkey, then cap. Use a small headroom so JSONL
  # files that get filtered out in pass 2 (only meta / <command-*>
  # entries) don't leave the list short.
  if (( max_sessions > 0 )); then
    headroom=$(( max_sessions * 2 + 5 ))
    while IFS= read -r line; do top+=("$line"); done \
      < <(printf '%s\n' "${candidates[@]}" | sort -r | head -n $headroom)
  else
    while IFS= read -r line; do top+=("$line"); done \
      < <(printf '%s\n' "${candidates[@]}" | sort -r)
  fi

  # Pass 2: for each surviving candidate, resolve branch/message if needed
  # and build the display rows. Newest-first order is preserved by sort -r
  # above and by `-o nosort` on the compadd call below. (Plain `-V` alone
  # isn't enough in some zsh setups; `-o nosort` is the canonical zsh API
  # that reliably disables the alphabetical re-sort.)
  for line in "${top[@]}"; do
    (( max_sessions > 0 && count >= max_sessions )) && break
    IFS=$'\t' read -r sortkey uuid src branch msg <<< "$line"
    datestr="${sortkey:0:10}"
    if [[ "$src" == "jsonl" ]]; then
      # Extract branch + first real user prompt.
      # Skip isMeta wrappers and <command-*> / <local-command-*> messages.
      # Emits nothing when no resumable user prompt exists, so files
      # containing only file-history-snapshots, hook progress, or
      # <command-*>/meta entries are filtered out — `claude --resume`
      # rejects those with "No conversation found".
      info=$(head -100 "$project_dir/$uuid.jsonl" | python3 -c '
import sys, json, re
users = []
for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        obj = json.loads(line)
    except Exception:
        continue
    if obj.get("type") == "user":
        users.append(obj)
if not users:
    sys.exit(0)
branch = users[0].get("gitBranch") or "?"
for u in users:
    if u.get("isMeta"):
        continue
    content = (u.get("message") or {}).get("content")
    if content is None:
        continue
    text = content[0].get("text") if isinstance(content, list) else content
    if not text:
        continue
    if re.match(r"^\s*<(command|local-command)", text):
        continue
    print(branch + "\t" + text.replace(chr(10), chr(32))[:60])
    sys.exit(0)
' 2>/dev/null)
      [[ -z "$info" ]] && continue
      branch="${info%%$'\t'*}"
      msg="${info#*$'\t'}"
    fi
    ids+=("$uuid")
    labels+=("${datestr} ${uuid:0:8}- [${branch}] ${msg}")
    (( count++ ))
  done

  [[ ${#ids} -eq 0 ]] && return 1
  local expl
  # `-V sessions` names the group (for zstyle targeting). `-o nosort` is
  # what actually disables alphabetical re-sorting — `-V` alone is
  # sometimes overridden by the display layer. `-o nosort` is the canonical
  # zsh API (used throughout core completion functions) and is stable in
  # zsh 5.0.1+, so this is safe for any modern zsh.
  _wanted session-ids expl 'session' compadd -V sessions -o nosort -d labels -a ids
}

# Offer a freshly-generated UUID for --session-id, which expects a NEW,
# user-assigned session identifier (not an existing session to resume).
local curcontext="$curcontext" state line
typeset -A opt_args

local -a commands
commands=(
  'agents:Manage background and configured agents'
  'auth:Manage authentication'
  'auto-mode:Inspect auto mode classifier configuration'
  'doctor:Check the health of your Claude Code auto-updater'
  'install:Install Claude Code native build. Use [target] to specify version (stable, latest, or specific version)'
  'mcp:Configure and manage MCP servers'
  'plugin:Manage Claude Code plugins'
  'plugins:Manage Claude Code plugins'
  'setup-token:Set up a long-lived authentication token (requires Claude subscription)'
  'remote-control:Connect your local environment to claude.ai/code'
  'update:Check for updates and install if available'
  'upgrade:Check for updates and install if available'
)

local -a auth_commands
auth_commands=(
  'help:Display help for command'
  'login:Sign in to your Anthropic account'
  'logout:Log out from your Anthropic account'
  'status:Show authentication status'
)

local -a mcp_commands
mcp_commands=(
  'add:Add an MCP server to Claude Code'
  'add-from-claude-desktop:Import MCP servers from Claude Desktop (Mac and WSL only)'
  'add-json:Add an MCP server (stdio or SSE) with a JSON string'

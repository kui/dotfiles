)

local -a plugin_commands
plugin_commands=(
  'disable:Disable an enabled plugin'
  'enable:Enable a disabled plugin'
  'help:Display help for command'
  'install:Install a plugin from available marketplaces (use plugin@marketplace for specific marketplace)'
  'i:Install a plugin from available marketplaces (use plugin@marketplace for specific marketplace)'
  'list:List installed plugins'
  'marketplace:Manage Claude Code marketplaces'
  'uninstall:Uninstall an installed plugin'
  'remove:Uninstall an installed plugin'
  'tag:Create a {name}--v{version} git tag for a plugin release'
  'update:Update a plugin to the latest version (restart required to apply)'
  'validate:Validate a plugin or marketplace manifest'
)

local -a marketplace_commands
marketplace_commands=(
  'add:Add a marketplace from a URL, path, or GitHub repo'
  'help:Display help for command'
  'list:List all configured marketplaces'
  'remove:Remove a configured marketplace'
  'rm:Remove a configured marketplace'
  'update:Update marketplace(s) from their source - updates all if no name specified'
)

# Find the subcommand position by scanning for the first non-flag argument after the command name.
# This handles cases where flags appear before the subcommand (e.g., alias claude='claude --flag').
local subcmd_pos=0
local subcmd=""
local -a known_commands=(agents auth auto-mode doctor install mcp plugin plugins remote-control setup-token update upgrade)
local i
for (( i=2; i <= ${#words}; i++ )); do
  # Skip flags and their values
  [[ "$words[$i]" == -* ]] && continue
  # Check if this word is a known subcommand
  if (( ${known_commands[(Ie)$words[$i]]} )); then
    subcmd_pos=$i
    subcmd="$words[$i]"
    break
  fi
done

# If no subcommand found yet, fall through to main _arguments
if [[ -n "$subcmd" ]]; then
# Calculate positions relative to the subcommand
local sub1=$(( subcmd_pos + 1 ))

case $subcmd in
  agents)
    _arguments \
      '(-h --help)'{-h,--help}'[Display help for command]' \
      '--setting-sources[Comma-separated list of setting sources to load (user, project, local)]:sources:'
    return
    ;;
  auth)
    if (( CURRENT == sub1 )); then
      _describe 'auth command' auth_commands
    else
      case $words[$sub1] in
        login)
          _arguments \
            '--claudeai[Use Claude subscription (default)]' \
            '--console[Use Anthropic Console (API usage billing) instead of Claude subscription]' \
            '--email[Pre-populate email address on the login page]:email:' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '--sso[Force SSO login flow]'
          ;;
        logout)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]'
          ;;
        status)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '--json[Output as JSON (default)]' \
            '--text[Output as human-readable text]'
          ;;
        *)
          _message 'no more arguments'
          ;;
      esac
    fi
    return
    ;;
  mcp)
    if (( CURRENT == sub1 )); then
      _describe 'mcp command' mcp_commands
    else
      case $words[$sub1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[Enable debug mode]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '--verbose[Override verbose mode setting from config]'
          ;;
        add)
          _arguments \
            '--callback-port[Fixed port for OAuth callback (for servers requiring pre-registered redirect URIs)]:port:' \
            '--client-id[OAuth client ID for HTTP/SSE servers]:clientId:' \
            '--client-secret[Prompt for OAuth client secret (or set MCP_CLIENT_SECRET env var)]' \
            '(-e --env)*'{-e,--env}'[Set environment variables (e.g. -e KEY=value)]:env:' \
            '(-H --header)*'{-H,--header}'[Set WebSocket headers (e.g. -H "X-Api-Key: abc123" -H "X-Custom: value")]:header:' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Configuration scope (local, user, or project) (default: local)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[Transport type (stdio, sse, http). Defaults to stdio if not specified]:transport:(stdio sse http)' \
            ':name:' \
            ':commandOrUrl:_files' \
            '*:args:_files'
          ;;
        remove)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Configuration scope (local, user, or project) - if not specified, removes from whichever scope it exists in]:scope:(local user project)' \
            ':name:'
          ;;
        add-json)
          _arguments \
            '--client-secret[Prompt for OAuth client secret (or set MCP_CLIENT_SECRET env var)]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Configuration scope (local, user, or project) (default: local)]:scope:(local user project)' \
            ':name:' \
            ':json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '--client-secret[Prompt for OAuth client secret (or set MCP_CLIENT_SECRET env var)]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Configuration scope (local, user, or project) (default: local)]:scope:(local user project)'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            ':name:'
          ;;
        list|reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]'
          ;;
        *)
          _message 'no more arguments'
          ;;
      esac
    fi
    return
    ;;
  plugin|plugins)
    if (( CURRENT == sub1 )); then
      _describe 'plugin command' plugin_commands
    else
      case $words[$sub1] in
        tag)
          _arguments \
            '--dry-run[Print what would be tagged without creating it]' \
            '(-f --force)'{-f,--force}'[Skip the dirty-working-tree and tag-already-exists checks]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-m --message)'{-m,--message}'[Tag annotation message (use %s for the version)]:msg:' \
            '--push[Push the tag to --remote after creating it]' \
            '--remote[Remote to push to with --push (default: origin)]:name:' \
            '::path:_files'
          ;;
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            ':path:_files'
          ;;
        marketplace)
          local sub2=$(( subcmd_pos + 2 ))
          if (( CURRENT == sub2 )); then
            _describe 'marketplace command' marketplace_commands
          else
            case $words[$sub2] in
              add)
                _arguments \
                  '(-h --help)'{-h,--help}'[Display help]' \
                  '--scope[Where to declare the marketplace: user (default), project, or local]:scope:(user project local)' \
                  '*--sparse[Limit checkout to specific directories via git sparse-checkout (for monorepos)]:path:_files -/' \
                  ':source:_files'
                ;;
              remove|rm)
                _arguments \
                  '(-h --help)'{-h,--help}'[Display help]' \
                  ':name:'
                ;;
              update)
                _arguments \
                  '(-h --help)'{-h,--help}'[Display help]' \
                  '::name:'
                ;;
              list)
                _arguments \
                  '(-h --help)'{-h,--help}'[Display help]' \
                  '--json[Output as JSON]'
                ;;
              *)
                _message 'no more arguments'
                ;;
            esac
          fi
          ;;
        install|i)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Installation scope: user, project, or local (default: user)]:scope:(user project local)' \
            ':plugin:'
          ;;
        uninstall|remove)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '--keep-data[Preserve the plugin'\''s persistent data directory (~/.claude/plugins/data/{id}/)]' \
            '(-s --scope)'{-s,--scope}'[Uninstall from scope: user, project, or local (default: user)]:scope:(user project local)' \
            ':plugin:'
          ;;
        enable)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Installation scope: user, project, local (default: auto-detect)]:scope:(user project local)' \
            ':plugin:'
          ;;
        disable)
          _arguments \
            '(-a --all)'{-a,--all}'[Disable all enabled plugins]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Installation scope: user, project, local (default: auto-detect)]:scope:(user project local)' \
            '::plugin:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Installation scope: user, project, local, managed (default: user)]:scope:(user project local managed)' \
            ':plugin:'
          ;;
        list)
          _arguments \
            '--available[Include available plugins from marketplaces (requires --json)]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '--json[Output as JSON]'
          ;;
        *)
          _message 'no more arguments'
          ;;
      esac
    fi
    return
    ;;
  auto-mode)
    if (( CURRENT == sub1 )); then
      local -a auto_mode_commands
      auto_mode_commands=(
        'config:Print the effective auto mode config as JSON: your settings where set, defaults otherwise'
        'critique:Get AI feedback on your custom auto mode rules'
        'defaults:Print the default auto mode environment, allow, and deny rules as JSON'
        'help:Display help for command'
      )
      _describe 'auto-mode command' auto_mode_commands
    else
      case $words[$sub1] in
        critique)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '--model[Override which model is used]:model:'
          ;;
        config|defaults)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]'
          ;;
        *)
          _message 'no more arguments'
          ;;
      esac
    fi
    return
    ;;
  install)
    _arguments \
      '--force[Force installation even if already installed]' \
      '(-h --help)'{-h,--help}'[Display help]' \
      ':target:(stable latest)'
    return
    ;;
  remote-control)
    _arguments \
      '(-h --help)'{-h,--help}'[Display help]' \
      '--sandbox[Enable sandboxing for filesystem and network isolation]' \
      '--no-sandbox[Disable sandboxing]' \
      '--verbose[Show detailed connection and session logs]'
    return
    ;;
  setup-token|doctor|update|upgrade)
    _arguments \
      '(-h --help)'{-h,--help}'[Display help]'
    return
    ;;
esac
fi # end: if [[ -n "$subcmd" ]]

# Only show global flags and commands if no subcommand matched
_arguments -s \
  '*--add-dir[Additional directories to allow tool access to]:directory:_files -/' \
  '--agent[Agent for the current session. Overrides the agent setting]:agent:' \
  '--agents[JSON object defining custom agents]:json:' \
  '--allow-dangerously-skip-permissions[Enable bypassing all permission checks as an option, without it being enabled by default. Recommended only for sandboxes with no internet access]' \
  '*--allowedTools[Comma or space-separated list of tool names to allow (e.g. "Bash(git:*) Edit")]:tools:' \
  '*--allowed-tools[Comma or space-separated list of tool names to allow (e.g. "Bash(git:*) Edit")]:tools:' \
  '--append-system-prompt[Append a system prompt to the default system prompt]:prompt:' \
  '--append-system-prompt-file[Append a system prompt from a file to the default system prompt]:file:_files' \
  '--bare[Minimal mode: skip hooks, LSP, plugin sync, attribution, auto-memory, background prefetches, keychain reads, and CLAUDE.md auto-discovery. Sets CLAUDE_CODE_SIMPLE=1]' \
  '*--betas[Beta headers to include in API requests (API key users only)]:betas:' \
  '--brief[Enable SendUserMessage tool for agent-to-user communication]' \
  '--chrome[Enable Claude in Chrome integration]' \
  '(-c --continue)'{-c,--continue}'[Continue the most recent conversation in the current directory]' \
  '--dangerously-skip-permissions[Bypass all permission checks. Recommended only for sandboxes with no internet access]' \
  '(-d --debug)'{-d,--debug}'[Enable debug mode with optional category filtering (e.g., "api,hooks" or "!1p,!file")]:filter:' \
  '--debug-file[Write debug logs to a specific file path (implicitly enables debug mode)]:path:_files' \
  '--disable-slash-commands[Disable all skills]' \
  '*--disallowedTools[Comma or space-separated list of tool names to deny (e.g. "Bash(git:*) Edit")]:tools:' \
  '*--disallowed-tools[Comma or space-separated list of tool names to deny (e.g. "Bash(git:*) Edit")]:tools:' \
  '--effort[Effort level for the current session (low, medium, high, xhigh, max)]:level:(low medium high xhigh max)' \
  '--exclude-dynamic-system-prompt-sections[Move per-machine sections (cwd, env info, memory paths, git status) from the system prompt into the first user message. Improves cross-user prompt-cache reuse. Only applies with the default system prompt (ignored with --system-prompt)]' \
  '--fallback-model[Enable automatic fallback to specified model when default model is overloaded (only works with --print)]:model:' \
  '*--file[File resources to download at startup. Format: file_id:relative_path (e.g., --file file_abc:doc.txt file_def:img.png)]:file:' \
  '--fork-session[When resuming, create a new session ID instead of reusing the original (use with --resume or --continue)]' \
  '--from-pr[Resume a session linked to a PR by PR number/URL, or open interactive picker with optional search term]:value:' \
  '(-h --help)'{-h,--help}'[Display help for command]' \
  '--ide[Automatically connect to IDE on startup if exactly one valid IDE is available]' \
  '--include-hook-events[Include all hook lifecycle events in the output stream (only works with --output-format=stream-json)]' \
  '--include-partial-messages[Include partial message chunks as they arrive (only works with --print and --output-format=stream-json)]' \
  '--input-format[Input format (only works with --print): "text" (default), or "stream-json" (realtime streaming input)]:format:(text stream-json)' \
  '--json-schema[JSON Schema for structured output validation. Example: {"type":"object","properties":{"name":{"type":"string"}},"required":["name"\]\}]:schema:' \
  '--max-budget-usd[Maximum dollar amount to spend on API calls (only works with --print)]:amount:' \
  '*--mcp-config[Load MCP servers from JSON files or strings (space-separated)]:config:_files' \
  '--mcp-debug[[DEPRECATED. Use --debug instead\] Enable MCP debug mode (shows MCP server errors)]' \
  '--model[Model for the current session. Provide an alias for the latest model (e.g. '\''sonnet'\'' or '\''opus'\'') or a model'\''s full name (e.g. '\''claude-sonnet-4-6'\'')]:model:' \
  '(-n --name)'{-n,--name}'[Set a display name for this session (shown in the prompt box, /resume picker, and terminal title)]:name:' \
  '--no-chrome[Disable Claude in Chrome integration]' \
  '--no-session-persistence[Disable session persistence - sessions will not be saved to disk and cannot be resumed (only works with --print)]' \
  '--output-format[Output format (only works with --print): "text" (default), "json" (single result), or "stream-json" (realtime streaming)]:format:(text json stream-json)' \
  '--permission-mode[Permission mode to use for the session]:mode:(acceptEdits bypassPermissions default dontAsk plan auto)' \
  '*--plugin-dir[Load plugins from directories for this session only (repeatable)]:directory:_files -/' \
  '(-p --print)'{-p,--print}'[Print response and exit (useful for pipes). Note: The workspace trust dialog is skipped when Claude is run with the -p mode. Only use this flag in directories you trust]' \
  '--remote-control-session-name-prefix[Prefix for auto-generated Remote Control session names (default: hostname)]:prefix:' \
  '--replay-user-messages[Re-emit user messages from stdin back on stdout for acknowledgment (only works with --input-format=stream-json and --output-format=stream-json)]' \
